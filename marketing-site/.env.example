# ─────────────────────────────────────────────────────────────────────────────
# Ecommerce Factory — marketing site environment.
#
# The marketing site can run as a standalone static landing page. Set these
# public URLs when you want the CTAs to open the deployed engine/admin/demo apps.
# ─────────────────────────────────────────────────────────────────────────────

# Example (optional):
# NEXT_PUBLIC_ANALYTICS_ID=

# Deployed engine storefront/admin.
# NEXT_PUBLIC_ENGINE_URL=https://your-engine.example.com
# NEXT_PUBLIC_ENGINE_ADMIN_URL=https://your-engine.example.com/admin/dashboard
# NEXT_PUBLIC_ENGINE_ASSISTANT_URL=https://your-engine.example.com/admin/assistant
# NEXT_PUBLIC_ENGINE_ORDERS_URL=https://your-engine.example.com/admin/orders
# NEXT_PUBLIC_ENGINE_CHECKOUT_URL=https://your-engine.example.com/checkout?product=camille-cashmere-coat

# Optional explicit demo editor URLs.
# NEXT_PUBLIC_DEMO_MAISON_NOIR_URL=https://your-engine.example.com/admin/editor/demo-maison-noir
# NEXT_PUBLIC_DEMO_LUMEN_URL=https://your-engine.example.com/admin/editor/demo-lumen
# NEXT_PUBLIC_DEMO_TERRA_ASH_URL=https://your-engine.example.com/admin/editor/demo-terra-ash
