# ─────────────────────────────────────────────────────────────────────────────
# Ecommerce Factory — environment.  Copy to .env.local (or run `npm run setup`).
# .env.local is created/updated for you by the CLI; you rarely edit this by hand.
# ─────────────────────────────────────────────────────────────────────────────

# PRODUCT_MODE — "production" (default) or "demo".
#   production : real stores only. Demo stores are NEVER served, even if
#                ACTIVE_CLIENT points at one (demo data can't leak to production).
#   demo       : allows the showcase demo stores to be served.
PRODUCT_MODE=production

# ACTIVE_CLIENT — force a specific store regardless of the request host.
#   Optional. Set automatically by `npm run setup` / `npm run create-store`.
#   Examples: client-a · demo-lumen · your-new-store-id
# ACTIVE_CLIENT=client-a

# Cloudflare Workers:
#   PRODUCT_MODE is mirrored in wrangler.jsonc under "vars".
#   Admin persistence uses the CLIENT_CONFIGS KV binding in wrangler.jsonc.
